# Codex loads *.rules files and applies the MOST restrictive decision when multiple rules match.

prefix_rule(
  pattern = ["git", ["status","log","diff","show","rev-parse","ls-files","cat-file","describe","grep","blame"]],
  decision = "allow",
  justification = "Allowed: read-only git commands.",
  match = [
    "git status",
    "git log --oneline -n 5",
    "git diff --stat",
  ],
)

prefix_rule(
  pattern = ["git", ["add","branch","checkout","cherry-pick","clean","commit","merge","pull","push","rebase","remote","reset","revert","stash","submodule","switch","tag"]],
  decision = "forbidden",
  justification = "Blocked: mutating git command (do it manually).",
  match = [
    "git commit -m test",
    "git push",
  ],
)

