{
  "name": "ofeed-board",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.15.0 <25",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:win": "vite",
    "build": "pnpm run type-check && pnpm run build-only",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.typecheck.json --composite false",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@tanstack/vue-query": "^5.100.14",
    "@unocss/reset": "^66.7.0",
    "@vueuse/core": "^13.0.0",
    "axios": "^1.16.1",
    "date-fns": "^2.29.3",
    "flag-icons": "^7.5.0",
    "graphql-ws": "^6.0.8",
    "pinia": "^3.0.0",
    "pinia-plugin-persistedstate": "^4.0.0",
    "vue": "3.5.35",
    "vue-i18n": "^9.14.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@iconify-json/mdi": "^1.2.0",
    "@pinia/testing": "^1.0.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/vue": "^8.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.12.4",
    "@unocss/preset-attributify": "^66.7.0",
    "@unocss/preset-icons": "^66.7.0",
    "@unocss/preset-wind3": "^66.7.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^3.0.0",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.60.0",
    "unocss": "^66.7.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.6",
    "vue-eslint-parser": "^10.0.0",
    "vue-tsc": "^3.3.2"
  }
}
