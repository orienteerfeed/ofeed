{
  "extends": "./tsconfig.base.json",
  "include": [
    "vite.config.*",
    "vitest.config.*",
    "playwright.config.*",
    "eslint.config.*"
  ],
  "compilerOptions": {
    "composite": true,
    "types": ["node"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023"],
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.config.tsbuildinfo"
  }
}
