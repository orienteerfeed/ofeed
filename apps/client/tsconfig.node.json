{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "outDir": "dist/tsconfig-node",
    "tsBuildInfoFile": "dist/tsconfig-node/tsconfig.node.tsbuildinfo",
    "strict": true,
    "types": ["node", "@playwright/test"]
  },
  "include": [
    "vite.config.ts",
    "vitest.config.ts",
    "playwright.config.ts",
    "e2e/**/*.ts"
  ]
}
