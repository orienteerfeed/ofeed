# Compose-only variables used for Docker and Traefik interpolation.
# This file is optional for local app runtime. Runtime env files stay app-local.

SERVER_PORT=3001
FRONTEND_PORT=3000
BOARD_PORT=3002

API_HOST=api.ofeed.local
FRONTEND_HOST=ofeed.local
BOARD_HOST=board.ofeed.local

TRAEFIK_ENTRYPOINT=https
TRAEFIK_CERT_RESOLVER=le

# Variables commonly shared with the external Traefik stack.
LETSENCRYPT_EMAIL=admin@example.com
LETSENCRYPT_CA_SERVER=https://acme-v02.api.letsencrypt.org/directory
